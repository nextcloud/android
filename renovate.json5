{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":gitSignOff"
    ],
    "timezone": "Europe/Berlin",
    "labels": [
        "dependencies",
        "3. to review"
    ],
	"rebaseWhen": "conflicted",
    "autoApprove": true,
    "automerge": true,
    "automergeType": "pr",
    "packageRules": [
        {
            "matchPackageNames": ["org.apache.jackrabbit:jackrabbit-webdav"],
            "groupName": "org.apache.jackrabbit",
            "matchCurrentVersion": "< 2.13.99",
            "enabled": false
        },
        {
            "matchPackageNames": ["com.google.code.findbugs:annotations"],
            "groupName": "com.google.code.findbugs",
            "matchCurrentVersion": "= 3.0.1u2",
            "enabled": false
        }
    ]
}
